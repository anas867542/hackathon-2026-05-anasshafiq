# Copy this file to .env.local for local dev, or .env.production for production.
# NEXT_PUBLIC_* values are baked into the JS bundle at build time — they are visible to browsers.

# NestJS API base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# NestJS API WebSocket URL (no trailing slash, no path)
NEXT_PUBLIC_API_WS_URL=http://localhost:4000

# Google Maps JavaScript API key
# Required APIs: Maps JavaScript API, Directions API, Distance Matrix API
# Restrict this key to your production domains in the GCP console.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
