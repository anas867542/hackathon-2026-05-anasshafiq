generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================
// ENUMS
// =====================
enum UserRole {
  customer
  driver
  admin
}

enum UserStatus {
  pending
  active
  suspended
  deleted
}

enum DriverStatus {
  offline
  online
  on_trip
  suspended
}

enum VehicleType {
  mini_truck
  pickup
  medium_truck
  large_truck
  container
  flatbed
  refrigerated
}

enum BookingType {
  instant
  bidding
  scheduled
}

enum BookingStatus {
  pending
  matched
  accepted
  arrived
  in_progress
  completed
  cancelled
  expired
}

enum BidStatus {
  pending
  accepted
  rejected
  withdrawn
  expired
}

enum PaymentMethod {
  card
  wallet
  cash
  bank_transfer
  mock
}

enum PaymentStatus {
  pending
  authorized
  captured
  failed
  refunded
}

// =====================
// MODELS
// =====================
model User {
  id            String     @id @default(uuid()) @db.Uuid
  email         String     @unique
  phone         String     @unique
  passwordHash  String     @map("password_hash")
  fullName      String     @map("full_name")
  role          UserRole
  status        UserStatus @default(pending)
  avatarUrl     String?    @map("avatar_url")
  emailVerifiedAt DateTime? @map("email_verified_at")
  phoneVerifiedAt DateTime? @map("phone_verified_at")
  lastLoginAt   DateTime?  @map("last_login_at")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt       @map("updated_at")
  deletedAt     DateTime?  @map("deleted_at")

  driver           Driver?
  bookingsAsCustomer Booking[] @relation("CustomerBookings")
  reviewsWritten   Review[]   @relation("ReviewsWritten")
  reviewsReceived  Review[]   @relation("ReviewsReceived")
  refreshTokens    RefreshToken[]

  @@index([role])
  @@index([status])
  @@map("users")
}

model RefreshToken {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  tokenHash  String   @unique @map("token_hash")
  expiresAt  DateTime @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Driver {
  id                 String       @id @default(uuid()) @db.Uuid
  userId             String       @unique @map("user_id") @db.Uuid
  licenseNumber      String       @unique @map("license_number")
  licenseExpiry      DateTime     @map("license_expiry") @db.Date
  cnicNumber         String?      @unique @map("cnic_number")
  licenseDocUrl      String?      @map("license_doc_url")
  docStatus          String       @default("pending") @map("doc_status")
  status             DriverStatus @default(offline)

  currentLat         Decimal?     @map("current_lat") @db.Decimal(10, 7)
  currentLng         Decimal?     @map("current_lng") @db.Decimal(10, 7)
  lastLocationAt     DateTime?    @map("last_location_at")

  ratingAvg          Decimal      @default(0) @map("rating_avg") @db.Decimal(3, 2)
  ratingCount        Int          @default(0) @map("rating_count")
  totalTrips         Int          @default(0) @map("total_trips")
  totalEarnings      Decimal      @default(0) @map("total_earnings") @db.Decimal(12, 2)

  isSubscribed       Boolean      @default(false) @map("is_subscribed")
  subscriptionUntil  DateTime?    @map("subscription_until")

  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt       @map("updated_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  trucks        Truck[]
  bookings      Booking[]      @relation("DriverBookings")
  bids          Bid[]
  tripLocations TripLocation[]

  @@index([status])
  @@map("drivers")
}

model Truck {
  id              String      @id @default(uuid()) @db.Uuid
  driverId        String      @map("driver_id") @db.Uuid
  type            VehicleType
  plateNumber     String      @unique @map("plate_number")
  capacityKg      Int         @map("capacity_kg")
  capacityVolumeM3 Decimal?   @map("capacity_volume_m3") @db.Decimal(6, 2)
  make            String?
  model           String?
  year            Int?
  color           String?
  registrationDocUrl String?  @map("registration_doc_url")
  insuranceDocUrl    String?  @map("insurance_doc_url")
  insuranceExpiry    DateTime? @map("insurance_expiry") @db.Date
  isPrimary       Boolean     @default(false) @map("is_primary")
  isActive        Boolean     @default(true) @map("is_active")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt       @map("updated_at")

  driver   Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([driverId])
  @@index([type])
  @@map("trucks")
}

model Booking {
  id                 String        @id @default(uuid()) @db.Uuid
  referenceCode      String        @unique @map("reference_code")

  customerId         String        @map("customer_id") @db.Uuid
  driverId           String?       @map("driver_id") @db.Uuid
  truckId            String?       @map("truck_id") @db.Uuid

  vehicleType        VehicleType   @map("vehicle_type")

  pickupAddress      String        @map("pickup_address")
  pickupLat          Decimal       @map("pickup_lat") @db.Decimal(10, 7)
  pickupLng          Decimal       @map("pickup_lng") @db.Decimal(10, 7)
  dropoffAddress     String        @map("dropoff_address")
  dropoffLat         Decimal       @map("dropoff_lat") @db.Decimal(10, 7)
  dropoffLng         Decimal       @map("dropoff_lng") @db.Decimal(10, 7)

  goodsDescription   String?       @map("goods_description")
  estimatedWeightKg  Int?          @map("estimated_weight_kg")
  distanceKm         Decimal?      @map("distance_km") @db.Decimal(8, 2)
  durationMinutes    Int?          @map("duration_minutes")

  estimatedFare      Decimal?      @map("estimated_fare") @db.Decimal(10, 2)
  finalFare          Decimal?      @map("final_fare") @db.Decimal(10, 2)

  bookingType        BookingType   @default(instant) @map("booking_type")
  status             BookingStatus @default(pending)

  scheduledAt        DateTime?     @map("scheduled_at")
  matchedAt          DateTime?     @map("matched_at")
  acceptedAt         DateTime?     @map("accepted_at")
  arrivedAt          DateTime?     @map("arrived_at")
  startedAt          DateTime?     @map("started_at")
  completedAt        DateTime?     @map("completed_at")
  cancelledAt        DateTime?     @map("cancelled_at")
  cancellationReason String?       @map("cancellation_reason")

  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt       @map("updated_at")

  customer      User           @relation("CustomerBookings", fields: [customerId], references: [id])
  driver        Driver?        @relation("DriverBookings", fields: [driverId], references: [id])
  truck         Truck?         @relation(fields: [truckId], references: [id])
  bids          Bid[]
  payment       Payment?
  reviews       Review[]
  tripLocations TripLocation[]

  @@index([customerId])
  @@index([driverId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  // Composite indexes for the common filtered list queries (customer list by status, driver list by status)
  @@index([customerId, status])
  @@index([driverId, status])
  @@map("bookings")
}

model Bid {
  id          String    @id @default(uuid()) @db.Uuid
  bookingId   String    @map("booking_id") @db.Uuid
  driverId    String    @map("driver_id") @db.Uuid
  amount      Decimal   @db.Decimal(10, 2)
  etaMinutes  Int?      @map("eta_minutes")
  message     String?
  status      BidStatus @default(pending)
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt       @map("updated_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  driver  Driver  @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@unique([bookingId, driverId])
  @@index([bookingId])
  @@index([driverId])
  // Composite index for listForBooking: WHERE booking_id = X AND status = 'pending'
  @@index([bookingId, status])
  @@map("bids")
}

model Payment {
  id                String        @id @default(uuid()) @db.Uuid
  bookingId         String        @unique @map("booking_id") @db.Uuid
  amount            Decimal       @db.Decimal(10, 2)
  currency          String        @default("PKR") @db.Char(3)
  commission        Decimal       @default(0) @db.Decimal(10, 2)
  driverPayout      Decimal       @default(0) @map("driver_payout") @db.Decimal(10, 2)
  method            PaymentMethod
  status            PaymentStatus @default(pending)
  provider          String?
  providerIntentId  String?       @map("provider_intent_id")
  providerChargeId  String?       @map("provider_charge_id")
  failureReason     String?       @map("failure_reason")
  authorizedAt      DateTime?     @map("authorized_at")
  capturedAt        DateTime?     @map("captured_at")
  refundedAt        DateTime?     @map("refunded_at")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt       @map("updated_at")

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([status])
  @@map("payments")
}

model Review {
  id          String   @id @default(uuid()) @db.Uuid
  bookingId   String   @map("booking_id") @db.Uuid
  reviewerId  String   @map("reviewer_id") @db.Uuid
  revieweeId  String   @map("reviewee_id") @db.Uuid
  score       Int
  comment     String?
  isHidden    Boolean  @default(false) @map("is_hidden")
  createdAt   DateTime @default(now()) @map("created_at")

  booking  Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  reviewer User    @relation("ReviewsWritten",  fields: [reviewerId], references: [id])
  reviewee User    @relation("ReviewsReceived", fields: [revieweeId], references: [id])

  @@unique([bookingId, reviewerId])
  @@index([revieweeId])
  @@map("reviews")
}

model TripLocation {
  id         String   @id @default(uuid()) @db.Uuid
  bookingId  String   @map("booking_id") @db.Uuid
  driverId   String   @map("driver_id") @db.Uuid
  lat        Decimal  @db.Decimal(10, 7)
  lng        Decimal  @db.Decimal(10, 7)
  speedKmh   Float?   @map("speed_kmh")
  heading    Float?
  recordedAt DateTime @default(now()) @map("recorded_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  driver  Driver  @relation(fields: [driverId], references: [id])

  @@index([bookingId, recordedAt])
  @@index([driverId, recordedAt])
  @@map("trip_locations")
}
