# Server
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:3000
BODY_LIMIT=1mb

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/transpolink?schema=public

# JWT — generate with: openssl rand -hex 32
# Both secrets MUST be at least 32 characters and different from each other.
# The server refuses to boot with placeholder or short secrets.
JWT_ACCESS_SECRET=replace-me-with-strong-secret-min-32-chars-aaaaaa
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=replace-me-with-another-strong-secret-min-32-chars
JWT_REFRESH_EXPIRES=7d

# Auth
BCRYPT_ROUNDS=12

# Google OAuth 2.0 — create credentials at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# Web app URL (used to redirect after Google OAuth)
WEB_APP_URL=http://localhost:3000

# Throttling (global default — auth endpoints have stricter limits)
THROTTLE_TTL=60
THROTTLE_LIMIT=100
